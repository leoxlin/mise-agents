#!/usr/bin/env bash
#MISE description="Run backend plugin tests"
set -euo pipefail

root="$(pwd)"
(cd "${root}/plugins/agents" && lua tests/hooks.lua)
(cd "${root}/plugins/skills" && lua tests/hooks.lua)

tmp="$(mktemp -d)"
trap 'rm -rf "${tmp}"' EXIT
unset MISE_CONFIG_FILE MISE_CONFIG_FILENAMES MISE_CONFIG_DIR
export HOME="${tmp}/home"
export CODEX_HOME="${tmp}/codex"
export CLAUDE_CONFIG_DIR="${tmp}/claude"
export MISE_DATA_DIR="${tmp}/mise/data"
export MISE_CACHE_DIR="${tmp}/mise/cache"
export MISE_STATE_DIR="${tmp}/mise/state"
export MISE_GLOBAL_CONFIG_FILE="${tmp}/mise/global.toml"
export XDG_CONFIG_HOME="${tmp}/xdg/config"
export XDG_CACHE_HOME="${tmp}/xdg/cache"
export XDG_STATE_HOME="${tmp}/xdg/state"
export MISE_CONFIG_DIR="${XDG_CONFIG_HOME}/mise"
export MISE_TRUSTED_CONFIG_PATHS="${tmp}/project"
mkdir -p \
    "${HOME}" \
    "${CODEX_HOME}" \
    "${CLAUDE_CONFIG_DIR}" \
    "${XDG_CONFIG_HOME}" \
    "${XDG_CACHE_HOME}" \
    "${XDG_STATE_HOME}" \
    "${tmp}/mise" \
    "${tmp}/project"
printf '\n' >"${MISE_GLOBAL_CONFIG_FILE}"

printf '%s\n' \
    '[plugins]' \
    '"vfox:agents" = "git::https://github.com/leoxlin/mise-agents.git//plugins/agents"' \
    '"vfox:skills" = "git::https://github.com/leoxlin/mise-agents.git//plugins/skills"' \
    '' \
    '[tools]' \
    'node = "24"' \
    '"agents:pi" = "0.80.7"' \
    '"skills:find-skills" = { version = "v1.5.20", source = "vercel-labs/skills" }' \
    >"${tmp}/project/mise.toml"
cd "${tmp}/project"

mise plugin link --force agents "${root}/plugins/agents"
mise plugin link --force skills "${root}/plugins/skills"

mise install skills:find-skills@v1.5.19
mise install skills:find-skills@v1.5.20
old_path="$(mise where skills:find-skills@v1.5.19)/.agents/skills/find-skills"
new_path="$(mise where skills:find-skills@v1.5.20)/.agents/skills/find-skills"

rm -f \
    "${CODEX_HOME}/skills/find-skills" \
    "${CLAUDE_CONFIG_DIR}/skills/find-skills" \
    "${HOME}/.agents/skills/find-skills" \
    "${HOME}/.pi/agent/skills/find-skills" \
    "${HOME}/.cursor/skills/find-skills"
mkdir -p "${HOME}/.agents/skills/find-skills"
printf 'keep\n' >"${HOME}/.agents/skills/find-skills/sentinel"
collision_output="$(mise exec skills:find-skills@v1.5.19 -- true 2>&1)"
if ! grep -q "Refusing to replace non-symlink skill destination" <<<"${collision_output}"; then
    echo "activation did not report the destination collision" >&2
    printf '%s\n' "${collision_output}" >&2
    exit 1
fi
test "$(cat "${HOME}/.agents/skills/find-skills/sentinel")" = "keep"
test ! -e "${CODEX_HOME}/skills/find-skills"
test ! -L "${CODEX_HOME}/skills/find-skills"
rm -rf "${HOME}/.agents/skills/find-skills"

assert_links() {
    local expected="$1"
    local phase="$2"
    local failed=0
    local destination actual

    printf 'links after %s (expected %s):\n' "${phase}" "${expected}"
    for destination in \
        "${CODEX_HOME}/skills/find-skills" \
        "${CLAUDE_CONFIG_DIR}/skills/find-skills" \
        "${HOME}/.agents/skills/find-skills" \
        "${HOME}/.pi/agent/skills/find-skills" \
        "${HOME}/.cursor/skills/find-skills"; do
        actual="$(readlink "${destination}" || true)"
        printf '  %s -> %s\n' "${destination}" "${actual:-<missing>}"
        if [[ "${actual}" != "${expected}" ]]; then
            failed=1
        fi
    done
    return "${failed}"
}

mise exec skills:find-skills@v1.5.19 -- true
assert_links "${old_path}" "find-skills v1.5.19 activation"
mise exec skills:find-skills@v1.5.20 -- true
assert_links "${new_path}" "find-skills v1.5.20 activation"

mise install agents:pi@0.80.7
mise exec agents:pi@0.80.7 skills:find-skills@v1.5.20 -- pi --version
assert_links "${new_path}" "combined Pi and find-skills v1.5.20 activation"

echo "live smoke: ok"
